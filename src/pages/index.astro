---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const herois = await getCollection('herois');
  return herois.map(heroi => ({
    params: { slug: heroi.id },
    props: { heroi }
  }));
}

const herois = await getCollection('herois');

// Serialize heroes data for client-side JS
const allHeroes = herois.map(h => ({
  id: h.id,
  nome: h.data.nome,
  titulo: h.data.titulo,
  periodo: h.data.periodo,
  foto: h.data.foto,
  tags: h.data.tags,
  body: h.body?.substring(0, 100) || ''
}));

const heroisJson = JSON.stringify(allHeroes).replace(/</g, '\\u003c');

const title = "Heróis Brasileiros — Histórias de Liderança e Coragem";
const description = "Conheça a história dos maiores heróis do Brasil.";
const itemsPerPage = 6;
---

<Layout title={title} description={description}>
  <section class="hero-header">
    <div class="header-bg"></div>
    <div class="container">
      <div class="header-content">
        <h1>🇧🇷 Heróis Brasileiros</h1>
        <p>Descubra as histórias de quem fez história no Brasil</p>
        <div class="header-stats">
          <div class="stat">
            <span class="number">{herois.length}</span>
            <span class="label">Heróis</span>
          </div>
          <div class="stat">
            <span class="number">∞</span>
            <span class="label">Legado</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <main class="container">
    <!-- Search Bar -->
    <form class="search-form" id="search-form">
      <input 
        type="text" 
        id="search-input"
        placeholder="🔍 Buscar heróis por nome, título, tag..." 
        class="search-input"
      />
      <button type="submit" class="search-btn">Buscar</button>
      <button type="button" id="shuffle-btn" class="shuffle-btn" title="Embaralhar">🔀</button>
    </form>

    <div class="results-info" id="results-info" style="display: none;">
      <span id="results-count"></span>
      <a href="/" class="clear-search">← Limpar</a>
    </div>

    <div class="heroes-grid" id="heroes-grid">
      <!-- Hero cards will be rendered by JS -->
    </div>

    <!-- Pagination -->
    <div class="pagination" id="pagination"></div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>🇧🇷 Heróis Brasileiros — Celebrando quem fez história</p>
      <p class="sub">Feito com 🇧🇷 e Astro</p>
    </div>
  </footer>
</Layout>

<script define:vars={{ heroisJson, itemsPerPage }}>
  const heroes = JSON.parse(heroisJson);
  let currentPage = 1;
  let filteredHeroes = [...heroes];

  function getThumb(url) {
    if (!url) return '';
    // For external URLs, add thumbnail params
    if (url.startsWith('http')) {
      return url.includes('?') ? url + '&w=200&h=200&fit=crop' : url + '?w=200&h=200&fit=crop';
    }
    // For local images, use direct path
    return url;
  }

  function shuffleArray(array) {
    const shuffled = [...array];
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled;
  }

  function renderHeroCard(heroi) {
    const thumb = getThumb(heroi.foto);
    const tagsHtml = heroi.tags ? heroi.tags.slice(0, 2).map(tag => `<span class="tag">${tag}</span>`).join('') : '';
    
    return `
      <a href="/herois/${heroi.id}" class="hero-card">
        <div class="card-badge">⭐</div>
        <div class="card-image">
          ${heroi.foto ? 
            `<img src="${thumb}" alt="${heroi.nome}" loading="lazy" />` : 
            `<div class="image-placeholder"><span>🦸</span></div>`
          }
        </div>
        <div class="card-content">
          <h2>${heroi.nome}</h2>
          <p class="subtitle">${heroi.titulo}</p>
          <div class="period-badge">
            <span>📅</span> ${heroi.periodo}
          </div>
          <p class="excerpt">${heroi.body}...</p>
          <div class="card-footer">
            <div class="tags">${tagsHtml}</div>
            <span class="read-more">Ler mais →</span>
          </div>
        </div>
      </a>
    `;
  }

  function renderPage(page) {
    const start = (page - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const pageHeroes = filteredHeroes.slice(start, end);
    
    const grid = document.getElementById('heroes-grid');
    grid.innerHTML = pageHeroes.map(renderHeroCard).join('');
    
    // Render pagination
    const totalPages = Math.ceil(filteredHeroes.length / itemsPerPage);
    const pagination = document.getElementById('pagination');
    
    if (totalPages > 1) {
      let paginationHtml = '';
      
      // Previous button
      if (page > 1) {
        paginationHtml += `<button class="page-btn" onclick="renderPage(${page - 1})">← Anterior</button>`;
      }
      
      // Page numbers
      for (let i = 1; i <= totalPages; i++) {
        if (i === page) {
          paginationHtml += `<span class="page-current">${i}</span>`;
        } else {
          paginationHtml += `<button class="page-btn" onclick="renderPage(${i})">${i}</button>`;
        }
      }
      
      // Next button
      if (page < totalPages) {
        paginationHtml += `<button class="page-btn" onclick="renderPage(${page + 1})">Próxima →</button>`;
      }
      
      pagination.innerHTML = paginationHtml;
    } else {
      pagination.innerHTML = '';
    }
  }

  function filterHeroes(query) {
    if (!query) {
      filteredHeroes = shuffleArray(heroes);
    } else {
      const q = query.toLowerCase();
      filteredHeroes = heroes.filter(heroi => 
        heroi.nome.toLowerCase().includes(q) ||
        heroi.titulo.toLowerCase().includes(q) ||
        (heroi.tags && heroi.tags.some(t => t.toLowerCase().includes(q))) ||
        heroi.body.toLowerCase().includes(q)
      );
    }
    
    currentPage = 1;
    renderPage(currentPage);
    
    // Show results info
    const resultsInfo = document.getElementById('results-info');
    const resultsCount = document.getElementById('results-count');
    if (query) {
      resultsInfo.style.display = 'flex';
      resultsCount.textContent = `${filteredHeroes.length} herói${filteredHeroes.length !== 1 ? 's' : ''} encontrado${filteredHeroes.length !== 1 ? 's' : ''}`;
    } else {
      resultsInfo.style.display = 'none';
    }
  }

  // Initial render
  filteredHeroes = shuffleArray(heroes);
  renderPage(currentPage);

  // Search form handler
  document.getElementById('search-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const query = document.getElementById('search-input').value;
    filterHeroes(query);
  });

  // Shuffle button
  document.getElementById('shuffle-btn').addEventListener('click', () => {
    filterHeroes(document.getElementById('search-input').value);
  });

  // Make renderPage globally available
  window.renderPage = renderPage;
</script>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }

  .hero-header {
    background: linear-gradient(135deg, #302681 0%, #1a1a4a 50%, #302681 100%);
    background-image: radial-gradient(ellipse at 30% 70%, rgba(0, 148, 64, 0.2) 0%, transparent 50%), radial-gradient(ellipse at 70% 30%, rgba(255, 203, 0, 0.2) 0%, transparent 50%), linear-gradient(135deg, #302681 0%, #1a1a4a 100%);
    padding: 4rem 0;
    color: white;
    position: relative;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .header-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 40c8 8 20 8 28 0s20-8 28 0' stroke='%23ffffff' stroke-width='2' fill='none' opacity='0.05'/%3E%3C/svg%3E");
  }

  .header-content { position: relative; text-align: center; }
  .header-content h1 { margin: 0 0 0.5rem; font-size: 3rem; text-shadow: 2px 2px 8px rgba(0,0,0,0.3); }
  .header-content p { margin: 0 0 2rem; color: rgba(255,255,255,0.85); font-size: 1.25rem; }

  .header-stats { display: flex; justify-content: center; gap: 3rem; }
  .header-stats .stat { text-align: center; }
  .header-stats .number { display: block; font-size: 2rem; font-weight: 700; color: #ffcb00; }
  .header-stats .label { font-size: 0.875rem; color: rgba(255,255,255,0.7); }

  .search-form { display: flex; gap: 1rem; margin-bottom: 1rem; }
  .search-input { flex: 1; padding: 1rem 1.5rem; border: 2px solid #e5e7eb; border-radius: 1rem; font-size: 1rem; transition: border-color 0.2s; }
  .search-input:focus { outline: none; border-color: #302681; }
  .search-btn { background: #302681; color: white; border: none; padding: 1rem 2rem; border-radius: 1rem; font-weight: 600; cursor: pointer; transition: background 0.2s; }
  .search-btn:hover { background: #241a5e; }
  .shuffle-btn { background: #009440; color: white; border: none; padding: 1rem; border-radius: 1rem; cursor: pointer; font-size: 1.2rem; }
  .shuffle-btn:hover { background: #007a33; }

  .results-info { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding: 1rem; background: #f3f4f6; border-radius: 0.5rem; }
  .clear-search { color: #302681; text-decoration: none; font-weight: 600; }
  .clear-search:hover { text-decoration: underline; }

  .heroes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; padding: 1rem 0 3rem; }

  .hero-card { background: white; border-radius: 1.5rem; overflow: hidden; text-decoration: none; box-shadow: 0 4px 20px rgba(0,0,0,0.08); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; display: flex; flex-direction: column; }
  .hero-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(48, 38, 129, 0.15); }

  .card-badge { position: absolute; top: 1rem; right: 1rem; font-size: 1.5rem; z-index: 1; }
  .card-image { height: 160px; background: linear-gradient(135deg, #302681, #009440); display: flex; align-items: center; justify-content: center; }
  .card-image img { width: 100%; height: 100%; object-fit: cover; }
  .card-image .image-placeholder { font-size: 5rem; }

  .card-content { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
  .card-content h2 { margin: 0; color: #302681; font-size: 1.5rem; }
  .card-content .subtitle { margin: 0.25rem 0 0.5rem; color: #009440; font-weight: 500; font-size: 0.95rem; }

  .period-badge { display: inline-flex; align-items: center; gap: 0.25rem; background: #f3f4f6; color: #4b5563; font-size: 0.8rem; padding: 0.25rem 0.75rem; border-radius: 1rem; width: fit-content; margin-bottom: 0.75rem; }
  .card-content .excerpt { margin: 0 0 1rem; color: #4b5563; font-size: 0.9rem; line-height: 1.5; flex: 1; }

  .card-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 1rem; border-top: 1px solid #e5e7eb; }
  .card-footer .tags { display: flex; gap: 0.4rem; }
  .card-footer .tag { background: linear-gradient(135deg, #ffcb00, #e5b800); color: #1a1a4a; font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 0.25rem; font-weight: 600; }
  .read-more { color: #302681; font-size: 0.85rem; font-weight: 600; }

  .pagination { display: flex; justify-content: center; gap: 0.5rem; padding: 2rem 0; }
  .page-btn { background: white; color: #302681; border: 2px solid #302681; padding: 0.5rem 1rem; border-radius: 0.5rem; cursor: pointer; font-weight: 600; transition: all 0.2s; }
  .page-btn:hover { background: #302681; color: white; }
  .page-current { background: #302681; color: white; padding: 0.5rem 1rem; border-radius: 0.5rem; font-weight: 600; }

  .footer { text-align: center; padding: 2rem 0; color: #9ca3af; border-top: 2px solid #ffcb00; background: #f9fafb; }
  .footer .sub { font-size: 0.85rem; margin-top: 0.5rem; }
</style>