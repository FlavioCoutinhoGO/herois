---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const herois = await getCollection('herois');
  return herois.map(heroi => ({
    params: { slug: heroi.id },
    props: { heroi }
  }));
}

const herois = await getCollection('herois');

// Função para thumbnail (para imagens locais, usa caminho direto)
function getThumb(url) {
  if (!url) return '';
  return url;
}

const title = "Heróis Brasileiros — Histórias de Liderança e Coragem";
const description = "Conheça a história dos maiores heróis do Brasil.";
---

<Layout title={title} description={description}>
  <section class="hero-header">
    <div class="header-bg"></div>
    <div class="container">
      <div class="header-content">
        <h1>🇧🇷 Heróis Brasileiros</h1>
        <p>Descubra as histórias de quem fez história no Brasil</p>
        <div class="header-stats">
          <div class="stat">
            <span class="number">{herois.length}</span>
            <span class="label">Heróis</span>
          </div>
          <div class="stat">
            <span class="number">∞</span>
            <span class="label">Legado</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <main class="container">
    <!-- Search Bar -->
    <form class="search-form" id="search-form">
      <input type="text" id="search-input" placeholder="🔍 Buscar por nome, tag, biografia..." class="search-input" />
      <button type="submit" class="search-btn">Buscar</button>
      <button type="button" id="clear-btn" class="clear-btn" style="display:none">✕</button>
    </form>

    <div class="results-info" id="results-info" style="display:none">
      <span id="results-count"></span>
      <a href="/" class="clear-search">🔄 Limpar</a>
    </div>

    <div class="heroes-grid" id="heroes-grid">
      {herois.map(heroi => (
        <a href={`/herois/${heroi.id}`} class="hero-card">
          <div class="card-badge">⭐</div>
          <div class="card-image">
            {heroi.data.foto ? (
              <img src={getThumb(heroi.data.foto)} alt={heroi.data.nome} loading="lazy" />
            ) : (
              <div class="image-placeholder"><span>🦸</span></div>
            )}
          </div>
          <div class="card-content">
            <h2>{heroi.data.nome}</h2>
            <p class="subtitle">{heroi.data.titulo}</p>
            <div class="period-badge"><span>📅</span> {heroi.data.periodo}</div>
            <p class="excerpt">{heroi.body?.substring(0, 80) || heroi.data.titulo}...</p>
            <div class="card-footer">
              <div class="tags">
                {heroi.data.tags?.slice(0, 2).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <span class="read-more">Ler mais →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>🇧🇷 Heróis Brasileiros — Celebrando quem fez história</p>
    </div>
  </footer>
</Layout>

<script>
  // Client-side search and pagination
  const heroes = Array.from(document.querySelectorAll('.hero-card'));
  const itemsPerPage = 6;
  let currentPage = 1;

  function showPage(page) {
    currentPage = page;
    const start = (page - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    
    heroes.forEach((card, index) => {
      card.style.display = (index >= start && index < end) ? 'flex' : 'none';
    });
  }

  function setupPagination(total) {
    const totalPages = Math.ceil(total / itemsPerPage);
    if (totalPages <= 1) return;
    
    // Hide all initially
    heroes.forEach((card, index) => {
      card.style.display = index < itemsPerPage ? 'flex' : 'none';
    });
  }

  // Initial setup
  setupPagination(heroes.length);

  // Search functionality
  const searchForm = document.getElementById('search-form');
  const searchInput = document.getElementById('search-input');
  const clearBtn = document.getElementById('clear-btn');
  
  searchForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const query = searchInput.value.toLowerCase();
    
    heroes.forEach(card => {
      const name = card.querySelector('h2').textContent.toLowerCase();
      const subtitle = card.querySelector('.subtitle').textContent.toLowerCase();
      const tags = Array.from(card.querySelectorAll('.tag')).map(t => t.textContent.toLowerCase()).join(' ');
      const body = card.querySelector('.excerpt').textContent.toLowerCase();
      
      const match = name.includes(query) || subtitle.includes(query) || tags.includes(query) || body.includes(query);
      card.style.display = match ? 'flex' : 'none';
    });
    
    // Show/hide clear button
    clearBtn.style.display = searchInput.value ? 'block' : 'none';
    
    // Show results info
    const resultsInfo = document.getElementById('results-info');
    const visibleCount = heroes.filter(c => c.style.display !== 'none').length;
    if (query) {
      resultsInfo.style.display = 'flex';
      document.getElementById('results-count').textContent = `${visibleCount} herói${visibleCount !== 1 ? 's' : ''}`;
    } else {
      resultsInfo.style.display = 'none';
    }
  });
  
  // Clear button
  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    clearBtn.style.display = 'none';
    heroes.forEach(card => card.style.display = 'flex');
    document.getElementById('results-info').style.display = 'none';
  });
</script>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }

  .hero-header {
    background: linear-gradient(135deg, #302681 0%, #1a1a4a 50%, #302681 100%);
    padding: 4rem 0;
    color: white;
    position: relative;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .header-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 40c8 8 20 8 28 0s20-8 28 0' stroke='%23ffffff' stroke-width='2' fill='none' opacity='0.05'/%3E%3C/svg%3E");
  }

  .header-content { position: relative; text-align: center; }
  .header-content h1 { margin: 0 0 0.5rem; font-size: 3rem; }
  .header-content p { margin: 0 0 2rem; color: rgba(255,255,255,0.85); font-size: 1.25rem; }

  .header-stats { display: flex; justify-content: center; gap: 3rem; }
  .header-stats .number { display: block; font-size: 2rem; font-weight: 700; color: #ffcb00; }
  .header-stats .label { font-size: 0.875rem; color: rgba(255,255,255,0.7); }

  .search-form { display: flex; gap: 1rem; margin-bottom: 2rem; }
  .search-input { flex: 1; padding: 1rem 1.5rem; border: 2px solid #e5e7eb; border-radius: 1rem; font-size: 1rem; }
  .search-input:focus { outline: none; border-color: #302681; }
  .clear-btn { background: #ef4444; color: white; border: none; padding: 1rem; border-radius: 1rem; cursor: pointer; font-size: 1rem; }
  .clear-btn:hover { background: #dc2626; }

  .search-btn { background: #302681; color: white; border: none; padding: 1rem 2rem; border-radius: 1rem; font-weight: 600; cursor: pointer; }
  .search-btn:hover { background: #241a5e; }

  .results-info { display: flex; justify-content: space-between; margin-bottom: 1rem; padding: 1rem; background: #f3f4f6; border-radius: 0.5rem; }
  .clear-search { color: #302681; text-decoration: none; font-weight: 600; }

  .heroes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; padding: 1rem 0 3rem; }

  .hero-card { background: white; border-radius: 1.5rem; overflow: hidden; text-decoration: none; box-shadow: 0 4px 20px rgba(0,0,0,0.08); transition: all 0.4s; position: relative; display: flex; flex-direction: column; }
  .hero-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(48, 38, 129, 0.15); }

  .card-badge { position: absolute; top: 1rem; right: 1rem; font-size: 1.5rem; z-index: 1; }
  .card-image { height: 160px; background: linear-gradient(135deg, #302681, #009440); display: flex; align-items: center; justify-content: center; }
  .card-image img { width: 100%; height: 100%; object-fit: cover; }
  .card-image .image-placeholder { font-size: 5rem; }

  .card-content { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
  .card-content h2 { margin: 0; color: #302681; font-size: 1.5rem; }
  .card-content .subtitle { margin: 0.25rem 0 0.5rem; color: #009440; font-weight: 500; font-size: 0.95rem; }

  .period-badge { display: inline-flex; align-items: center; gap: 0.25rem; background: #f3f4f6; color: #4b5563; font-size: 0.8rem; padding: 0.25rem 0.75rem; border-radius: 1rem; width: fit-content; margin-bottom: 0.75rem; }
  .card-content .excerpt { margin: 0 0 1rem; color: #4b5563; font-size: 0.9rem; line-height: 1.5; flex: 1; }

  .card-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 1rem; border-top: 1px solid #e5e7eb; }
  .card-footer .tags { display: flex; gap: 0.4rem; }
  .card-footer .tag { background: linear-gradient(135deg, #ffcb00, #e5b800); color: #1a1a4a; font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 0.25rem; font-weight: 600; }
  .read-more { color: #302681; font-size: 0.85rem; font-weight: 600; }

  .footer { text-align: center; padding: 2rem 0; color: #9ca3af; border-top: 2px solid #ffcb00; background: #f9fafb; }
</style>