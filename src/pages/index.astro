---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const herois = await getCollection('herois');
  return herois.map(heroi => ({
    params: { slug: heroi.id },
    props: { heroi }
  }));
}

const herois = await getCollection('herois');

const title = "Heróis Brasileiros — Histórias de Liderança e Coragem";
const description = "Conheça a história dos maiores heróis do Brasil. Tiradentes, Zumbi dos Palmares, Santos Dumont e muito mais.";
---

<Layout title={title} description={description}>
  <!-- Hero Header -->
  <section class="hero-header">
    <div class="header-bg"></div>
    <div class="container">
      <div class="header-content">
        <h1>🇧🇷 Heróis Brasileiros</h1>
        <p>Descubra as histórias de quem fez história no Brasil</p>
        <div class="header-stats">
          <div class="stat">
            <span class="number">{herois.length}</span>
            <span class="label">Heróis</span>
          </div>
          <div class="stat">
            <span class="number">3</span>
            <span class="label">Seculos</span>
          </div>
          <div class="stat">
            <span class="number">∞</span>
            <span class="label">Legado</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <main class="container">
    <!-- Intro -->
    <div class="intro">
      <p>Estos brasileiros marcaram a história com suas ações, coragem e contribuições para o desenvolvimento do país.</p>
    </div>

    <!-- Heroes Grid -->
    <div class="heroes-grid">
      {herois.map(heroi => (
        <a href={`/herois/${heroi.id}`} class="hero-card">
          <div class="card-badge">⭐</div>
          <div class="card-image">
            <div class="image-placeholder">
              <span>🦸</span>
            </div>
          </div>
          <div class="card-content">
            <h2>{heroi.data.nome}</h2>
            <p class="subtitle">{heroi.data.titulo}</p>
            <div class="period-badge">
              <span>📅</span> {heroi.data.periodo}
            </div>
            <p class="excerpt">{heroi.body?.substring(0, 100) || heroi.data.titulo}...</p>
            <div class="card-footer">
              <div class="tags">
                {heroi.data.tags.slice(0, 2).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <span class="read-more">Ler mais →</span>
            </div>
          </div>
        </a>
      ))}

      <!-- Card Adicionar Novo (visual) -->
      <div class="hero-card add-new">
        <div class="add-content">
          <span class="plus">+</span>
          <p>Adicionar novo herói</p>
          <span class="hint">Edite o arquivo Markdown</span>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <p>🇧🇷 Heróis Brasileiros — Celebrando quem fez história</p>
      <p class="sub">Feito com 🇧🇷 e Astro</p>
    </div>
  </footer>
</Layout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }

  /* Hero Header */
  .hero-header {
    background: linear-gradient(135deg, var(--azul) 0%, #1a1a4a 50%, var(--azul) 100%);
    background-image: 
      radial-gradient(ellipse at 30% 70%, rgba(0, 148, 64, 0.2) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 30%, rgba(255, 203, 0, 0.2) 0%, transparent 50%),
      linear-gradient(135deg, var(--azul) 0%, #1a1a4a 100%);
    padding: 4rem 0;
    color: white;
    position: relative;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .header-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 40c8 8 20 8 28 0s20-8 28 0' stroke='%23ffffff' stroke-width='2' fill='none' opacity='0.05'/%3E%3C/svg%3E");
  }

  .header-content { position: relative; text-align: center; }

  .header-content h1 {
    margin: 0 0 0.5rem;
    font-size: 3rem;
    text-shadow: 2px 2px 8px rgba(0,0,0,0.3);
  }

  .header-content p {
    margin: 0 0 2rem;
    color: rgba(255,255,255,0.85);
    font-size: 1.25rem;
  }

  .header-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
  }

  .header-stats .stat {
    text-align: center;
  }

  .header-stats .number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--amarelo);
  }

  .header-stats .label {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
  }

  /* Intro */
  .intro {
    text-align: center;
    margin-bottom: 2rem;
    color: var(--cinza-600);
    font-size: 1.1rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Heroes Grid */
  .heroes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    padding: 1rem 0 3rem;
  }

  .hero-card {
    background: white;
    border-radius: 1.5rem;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .hero-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(48, 38, 129, 0.15);
  }

  .card-badge {
    position: absolute;
    top: 1rem; right: 1rem;
    font-size: 1.5rem;
    z-index: 1;
  }

  .card-image {
    height: 160px;
    background: linear-gradient(135deg, var(--azul), var(--verde));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image .image-placeholder {
    font-size: 5rem;
  }

  .card-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-content h2 {
    margin: 0;
    color: var(--azul);
    font-size: 1.5rem;
  }

  .card-content .subtitle {
    margin: 0.25rem 0 0.5rem;
    color: var(--verde);
    font-weight: 500;
    font-size: 0.95rem;
  }

  .period-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--cinza-100);
    color: var(--cinza-600);
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    width: fit-content;
    margin-bottom: 0.75rem;
  }

  .card-content .excerpt {
    margin: 0 0 1rem;
    color: var(--cinza-600);
    font-size: 0.9rem;
    line-height: 1.5;
    flex: 1;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--cinza-100);
  }

  .card-footer .tags {
    display: flex;
    gap: 0.4rem;
  }

  .card-footer .tag {
    background: linear-gradient(135deg, var(--amarelo), #e5b800);
    color: #1a1a4a;
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    font-weight: 600;
  }

  .read-more {
    color: var(--azul);
    font-size: 0.85rem;
    font-weight: 600;
  }

  /* Card Adicionar */
  .hero-card.add-new {
    border: 3px dashed var(--cinza-300);
    background: var(--cinza-50);
    min-height: 400px;
    justify-content: center;
    align-items: center;
    cursor: pointer;
  }

  .hero-card.add-new:hover {
    border-color: var(--amarelo);
    background: #fffbeb;
  }

  .add-content {
    text-align: center;
    color: var(--cinza-400);
  }

  .add-content .plus {
    font-size: 4rem;
    display: block;
    color: var(--cinza-300);
  }

  .add-content p {
    margin: 0.5rem 0;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .add-content .hint {
    font-size: 0.8rem;
  }

  /* Footer */
  .footer {
    text-align: center;
    padding: 2rem 0;
    color: var(--cinza-400);
    border-top: 2px solid var(--amarelo);
    background: var(--cinza-50);
  }

  .footer .sub {
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }

  /* Cores como variáveis */
  :root {
    --verde: #009440;
    --amarelo: #ffcb00;
    --azul: #302681;
    --branco: #FFFFFF;
    --cinza-50: #f9fafb;
    --cinza-100: #f3f4f6;
    --cinza-300: #d1d5db;
    --cinza-400: #9ca3af;
    --cinza-600: #4b5563;
  }
</style>