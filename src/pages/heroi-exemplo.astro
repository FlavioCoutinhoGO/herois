---
// src/pages/heroi-avançado.astro
// Este é um exemplo de página COMPLETA em Astro — sem Markdown

// Você pode importar dados de qualquer lugar
import { herois } from '../data/herois.json';

// Definir variáveis
const titulo = "Tiradentes - Herói Nacional";
const descricao = "A história de Tiradentes, mártir da independência brasileira";

// Funções JavaScript diretamente no componente
function formatarData(data) {
  return new Date(data).toLocaleDateString('pt-BR');
}

// Condicionais
const isDestaque = true;
const visitantes = 1543;
---

<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{titulo}</title>
  <meta name="description" content={descricao} />
</head>
<body>
  <!-- Header com JavaScript inline -->
  <header class:list={["header", { destaque: isDestaque }]}>
    <h1>🦸 {titulo}</h1>
    {isDestaque && <span class="badge">Em destaque</span>}
  </header>

  <!-- Container principal -->
  <main class="container">
    <!-- Section com dados do herói -->
    <section class="perfil">
      <img src="/herois/tiradentes.jpg" alt="Tiradentes" />
      
      <div class="info">
        <h2>Joaquim José da Silva Xavier</h2>
        <p class="periodo">1746 - 1792</p>
        <p class="bio">Dentista, minerador e ativista político — líder da Inconfidência Mineira.</p>
        
        <!-- Loop através de tags -->
        <div class="tags">
          {['Independência', 'Minas Gerais', 'Século XVIII'].map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Estatísticas (JS no template) -->
    <section class="stats">
      <div class="stat">
        <span class="numero">{visitantes}</span>
        <span class="label">visitantes este mês</span>
      </div>
      <div class="stat">
        <span class="numero">{formatarData('2026-04-03')}</span>
        <span class="label">última atualização</span>
      </div>
    </section>

    <!-- Conteúdo HTML simples -->
    <section class="biografia">
      <h3>Biografia</h3>
      <p>
        Tiradentes foi um dos líderes do movimento separatista conhecido como 
        <strong>Inconfidência Mineira</strong>. O movimento buscava a independência 
        de Minas Gerais do domínio português.
      </p>
      <p>
        Descoberto e preso em <time datetime="1789">1789</time>, Tiradentes foi julgado 
        e condenado à morte por enforcamento em <time datetime="1792-04-21">21 de abril de 1792</time>.
      </p>
    </section>

    <!-- Componente filho importado -->
    <section class="fonte">
      <p>Fonte: <a href="https://pt.wikipedia.org/wiki/Tiradentes">Wikipedia</a></p>
    </section>
  </main>

  <!-- Footer simples -->
  <footer>
    <p>&copy; 2026 Heróis Brasileiros</p>
  </footer>
</body>
</html>

<style>
  /* CSS scoped - só afeta este componente */
  .header {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    padding: 2rem;
    color: white;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header.destaque {
    padding: 3rem;
  }

  .badge {
    background: #fbbf24;
    color: #92400e;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .perfil {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .perfil img {
    width: 200px;
    height: 200px;
    border-radius: 1rem;
    object-fit: cover;
  }

  .perfil h2 {
    margin: 0;
    font-size: 1.5rem;
  }

  .periodo {
    color: #6b7280;
    font-size: 0.875rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    background: #e0e7ff;
    color: #4338ca;
    padding: 0.25rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
  }

  .stats {
    display: flex;
    gap: 2rem;
    background: #f9fafb;
    padding: 1.5rem;
    border-radius: 1rem;
    margin-bottom: 2rem;
  }

  .stat {
    text-align: center;
  }

  .numero {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
  }

  .label {
    font-size: 0.875rem;
    color: #6b7280;
  }

  .biografia h3 {
    color: #111827;
    font-size: 1.25rem;
  }

  .biografia p {
    color: #374151;
    line-height: 1.75;
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: #9ca3af;
    border-top: 1px solid #e5e7eb;
  }
</style>