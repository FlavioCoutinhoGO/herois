---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const herois = await getCollection('herois');
  // Gerar caminhos para galeria de cada herói
  return herois.map(heroi => ({
    params: { slug: heroi.id, rest: 'galeria' },
    props: { 
      data: heroi.data,
      rawBody: heroi.body
    }
  }));
}

const { data } = Astro.props;
const fotos = data.fotos || [];

// Imagens padrão
const defaultFotos = [
  { url: "https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=800", descricao: "Imagem representativa da história do Brasil", copyright: "Unsplash (livre uso)" },
  { url: "https://images.unsplash.com/photo-1531844251246-9a1bfaaeeb9a?w=800", descricao: "Cena histórica brasileira", copyright: "Unsplash (livre uso)" },
  { url: "https://images.unsplash.com/photo-1580130547518-2bcf0c44ce67?w=800", descricao: "Patrimônio cultural brasileiro", copyright: "Unsplash (livre uso)" },
  { url: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800", descricao: "Arte e cultura nacional", copyright: "Unsplash (livre uso)" }
];

const todasFotos = fotos.length > 0 
  ? fotos.map((url, i) => ({ url, descricao: `Foto ${i + 1} de ${data.nome}`, copyright: "© Acervo pessoal / Domínio público" }))
  : defaultFotos;

const title = `Galeria de Fotos — ${data.nome}`;
const description = `Veja as fotos e imagens de ${data.nome}, ${data.titulo}`;
---

<Layout title={title} description={description}>
  <section class="gallery-header">
    <div class="container">
      <a href={`/herois/${data.nome.toLowerCase().replace(/ /g, '-')}`} class="back-link">← Voltar ao perfil de {data.nome}</a>
      <h1>🖼️ Galeria de Fotos</h1>
      <p class="subtitle">{data.nome} — {data.titulo}</p>
    </div>
  </section>

  <main class="container">
    <div class="gallery-info">
      <p>Total de imagens: <strong>{todasFotos.length}</strong></p>
      <p class="note">💡 Clique em uma imagem para ampliar</p>
    </div>

    <div class="gallery-grid">
      {todasFotos.map((foto, index) => (
        <div class="gallery-item">
          <a href={`#img-${index}`} class="gallery-link">
            <img src={foto.url} alt={foto.descricao} loading="lazy" />
            <div class="item-overlay">
              <span class="zoom-icon">🔍</span>
            </div>
          </a>
        </div>
      ))}
    </div>

    <!-- Lightbox -->
    <div class="lightbox-container">
      {todasFotos.map((foto, index) => (
        <div id={`img-${index}`} class="lightbox-item">
          <div class="lightbox-content">
            <a href="#" class="close-btn">✕</a>
            <img src={foto.url} alt={foto.descricao} />
            <div class="lightbox-info">
              <h3>{foto.descricao}</h3>
              <p class="copyright">📋 {foto.copyright}</p>
              <a href={foto.url} download target="_blank" class="download-btn">
                ⬇️ Baixar imagem
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>🇧🇷 Heróis Brasileiros — Celebrando quem fez história</p>
    </div>
  </footer>
</Layout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }

  .gallery-header {
    background: linear-gradient(135deg, var(--azul) 0%, #1a1a4a 100%);
    padding: 2rem 0;
    color: white;
    margin-bottom: 2rem;
  }

  .gallery-header h1 { margin: 1rem 0 0.5rem; font-size: 2rem; }
  .gallery-header .subtitle { margin: 0; color: var(--amarelo); font-size: 1.1rem; }

  .back-link { color: var(--amarelo); text-decoration: none; font-size: 0.95rem; }
  .back-link:hover { color: white; }

  .gallery-info { text-align: center; margin-bottom: 2rem; color: var(--cinza-600); }
  .gallery-info strong { color: var(--azul); }
  .gallery-info .note { font-size: 0.9rem; color: var(--cinza-500); margin-top: 0.5rem; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .gallery-item {
    aspect-ratio: 4/3;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    transition: transform 0.3s;
  }

  .gallery-item:hover { transform: scale(1.03); }

  .gallery-link { display: block; width: 100%; height: 100%; position: relative; }
  .gallery-link img { width: 100%; height: 100%; object-fit: cover; }

  .item-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(48, 38, 129, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .gallery-link:hover .item-overlay { opacity: 1; }
  .zoom-icon { font-size: 3rem; }

  /* Lightbox */
  .lightbox-container { display: none; }

  :target.lightbox-item { 
    display: flex !important;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.95);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s;
  }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .lightbox-content {
    max-width: 90%;
    max-height: 90%;
    text-align: center;
    position: relative;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: 70vh;
    border-radius: 0.5rem;
    box-shadow: 0 10px 50px rgba(0,0,0,0.5);
  }

  .lightbox-info {
    background: white;
    padding: 1.5rem;
    border-radius: 0 0 0.5rem 0.5rem;
    margin-top: -0.5rem;
    text-align: left;
  }

  .lightbox-info h3 { margin: 0 0 0.5rem; color: var(--azul); font-size: 1.1rem; }
  .lightbox-info .copyright { margin: 0 0 1rem; color: var(--cinza-500); font-size: 0.85rem; }

  .download-btn {
    display: inline-block;
    background: var(--verde);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s;
  }

  .download-btn:hover { background: #007a33; }

  .close-btn {
    position: fixed;
    top: 1rem;
    right: 1rem;
    background: white;
    color: var(--azul);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: bold;
    z-index: 1001;
  }

  .footer { text-align: center; padding: 2rem 0; color: var(--cinza-400); border-top: 2px solid var(--amarelo); margin-top: 2rem; }

  :root {
    --verde: #009440;
    --amarelo: #ffcb00;
    --azul: #302681;
    --cinza-400: #9ca3af;
    --cinza-500: #6b7280;
    --cinza-600: #4b5563;
  }
</style>