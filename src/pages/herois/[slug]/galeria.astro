---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const herois = await getCollection('herois');
  return herois.map(heroi => ({
    params: { slug: heroi.id, rest: 'galeria' },
    props: { 
      data: heroi.data,
      rawBody: heroi.body
    }
  }));
}

const { data } = Astro.props;
const fotos = data.fotos || [];

const defaultFotos = [
  { url: "https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=800", descricao: "Imagem representativa da história do Brasil", copyright: "Unsplash (livre uso)" },
  { url: "https://images.unsplash.com/photo-1531844251246-9a1bfaaeeb9a?w=800", descricao: "Cena histórica brasileira", copyright: "Unsplash (livre uso)" },
  { url: "https://images.unsplash.com/photo-1580130547518-2bcf0c44ce67?w=800", descricao: "Patrimônio cultural brasileiro", copyright: "Unsplash (livre uso)" },
  { url: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800", descricao: "Arte e cultura nacional", copyright: "Unsplash (livre uso)" }
];

const todasFotos = fotos.length > 0 
  ? fotos.map((foto) => ({ 
      url: foto.url || foto, 
      descricao: foto.descricao || `Foto de ${data.nome}`, 
      copyright: foto.copyright || "© Acervo pessoal / Domínio público" 
    }))
  : defaultFotos;

const title = `Galeria de Fotos — ${data.nome}`;
const description = `Veja as fotos e imagens de ${data.nome}, ${data.titulo}`;
---

<Layout title={title} description={description}>
  <section class="gallery-header">
    <div class="container">
      <a href={`/herois/${data.nome.toLowerCase().replace(/ /g, '-')}`} class="back-link">← Voltar ao perfil de {data.nome}</a>
      <h1>🖼️ Galeria de Fotos</h1>
      <p class="subtitle">{data.nome} — {data.titulo}</p>
    </div>
  </section>

  <main class="container">
    <div class="gallery-info">
      <p>Total de imagens: <strong>{todasFotos.length}</strong></p>
      <p class="note">💡 Clique em uma imagem para ampliar e ver detalhes</p>
    </div>

    <div class="gallery-grid">
      {todasFotos.map((foto, index) => (
        <button class="gallery-item" data-index={index}>
          <img src={foto.url} alt={foto.descricao} loading="lazy" />
        </button>
      ))}
    </div>

    <div id="lightbox" class="lightbox">
      <div class="lightbox-backdrop"></div>
      <div class="lightbox-content">
        <button class="close-btn">✕</button>
        <img id="lightbox-img" src="" alt="" />
        <div class="lightbox-info">
          <h3 id="lightbox-desc"></h3>
          <p id="lightbox-copyright" class="copyright"></p>
          <a id="lightbox-download" href="" download target="_blank" class="download-btn">⬇️ Baixar imagem</a>
        </div>
        <div class="lightbox-nav">
          <button id="prev-btn">← Anterior</button>
          <span id="lightbox-counter"></span>
          <button id="next-btn">Próxima →</button>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>🇧🇷 Heróis Brasileiros — Celebrando quem fez história</p>
    </div>
  </footer>
</Layout>

<script define:vars={{ fotos: todasFotos }}>
  let currentIndex = 0;
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxDesc = document.getElementById('lightbox-desc');
  const lightboxCopyright = document.getElementById('lightbox-copyright');
  const lightboxDownload = document.getElementById('lightbox-download');
  const lightboxCounter = document.getElementById('lightbox-counter');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  function showImage(index) {
    currentIndex = index;
    const foto = fotos[index];
    lightboxImg.src = foto.url;
    lightboxImg.alt = foto.descricao;
    lightboxDesc.textContent = foto.descricao;
    lightboxCopyright.textContent = '📋 ' + foto.copyright;
    lightboxDownload.href = foto.url;
    lightboxCounter.textContent = (index + 1) + ' / ' + fotos.length;
    prevBtn.style.display = index === 0 ? 'none' : 'inline-block';
    nextBtn.style.display = index === fotos.length - 1 ? 'none' : 'inline-block';
  }

  function closeLightbox() {
    lightbox.classList.remove('active');
  }

  function navigate(direction) {
    const newIndex = currentIndex + direction;
    if (newIndex >= 0 && newIndex < fotos.length) {
      showImage(newIndex);
    }
  }

  // Add click handlers to gallery items
  document.querySelectorAll('.gallery-item').forEach((item) => {
    item.addEventListener('click', () => {
      const index = parseInt(item.dataset.index);
      showImage(index);
      lightbox.classList.add('active');
    });
  });

  // Navigation buttons
  prevBtn.addEventListener('click', () => navigate(-1));
  nextBtn.addEventListener('click', () => navigate(1));

  // Close handlers
  document.querySelector('.close-btn').addEventListener('click', closeLightbox);
  document.querySelector('.lightbox-backdrop').addEventListener('click', closeLightbox);

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });
</script>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }

  .gallery-header { background: linear-gradient(135deg, #302681 0%, #1a1a4a 100%); padding: 2rem 0; color: white; margin-bottom: 2rem; }
  .gallery-header h1 { margin: 1rem 0 0.5rem; font-size: 2rem; }
  .gallery-header .subtitle { margin: 0; color: #ffcb00; font-size: 1.1rem; }
  .back-link { color: #ffcb00; text-decoration: none; font-size: 0.95rem; }
  .back-link:hover { color: white; }

  .gallery-info { text-align: center; margin-bottom: 2rem; color: #4b5563; }
  .gallery-info strong { color: #302681; }
  .gallery-info .note { font-size: 0.9rem; color: #6b7280; margin-top: 0.5rem; }

  .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 3rem; }

  .gallery-item { aspect-ratio: 4/3; border-radius: 1rem; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.1); transition: transform 0.3s; cursor: pointer; border: none; padding: 0; background: none; }
  .gallery-item:hover { transform: scale(1.03); }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  .lightbox { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000; }
  .lightbox.active { display: block; }

  .lightbox-backdrop { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.9); }

  .lightbox-content { position: relative; z-index: 1; max-width: 90%; max-height: 90%; margin: 2rem auto; display: flex; flex-direction: column; align-items: center; }

  #lightbox-img { max-width: 100%; max-height: 60vh; border-radius: 0.5rem; box-shadow: 0 10px 50px rgba(0,0,0,0.5); }

  .lightbox-info { background: white; padding: 1rem 2rem; border-radius: 0 0 0.5rem 0.5rem; text-align: center; width: 100%; max-width: 600px; }
  .lightbox-info h3 { margin: 0 0 0.5rem; color: #302681; font-size: 1.1rem; }
  .lightbox-info .copyright { margin: 0 0 1rem; color: #6b7280; font-size: 0.85rem; }

  .download-btn { display: inline-block; background: #009440; color: white; padding: 0.75rem 1.5rem; border-radius: 0.5rem; text-decoration: none; font-weight: 600; transition: background 0.2s; }
  .download-btn:hover { background: #007a33; }

  .close-btn { position: fixed; top: 1rem; right: 1rem; background: white; color: #302681; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; border: none; cursor: pointer; }

  .lightbox-nav { display: flex; align-items: center; gap: 1rem; margin-top: 1rem; color: white; }
  .nav-btn { background: #302681; color: white; border: 2px solid #ffcb00; padding: 0.5rem 1rem; border-radius: 0.5rem; cursor: pointer; font-size: 0.9rem; font-weight: 600; transition: all 0.2s; }
  .nav-btn:hover { background: #241a5e; border-color: #e5b800; }
  #lightbox-counter { font-size: 0.9rem; color: rgba(255,255,255,0.7); }

  .footer { text-align: center; padding: 2rem 0; color: #9ca3af; border-top: 2px solid #ffcb00; margin-top: 2rem; }
</style>
